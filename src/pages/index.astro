---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import Weather from '../components/Weather.astro';
import { cover, areaColor, marqueeItems, issueNumbers, withBase } from '../lib/theme';

const all = await getCollection('issues');
const numbers = issueNumbers(all.map((i) => i.id));
// Newest first — highest derived issue number on top.
const issues = [...all].sort((a, b) => numbers.get(b.id)! - numbers.get(a.id)!);
const latest = issues[0];
const archive = issues.slice(1);

const latestNo = numbers.get(latest.id)!;
const latestCover = cover(latest.data.cover);
const latestHref = withBase(`issues/${latest.id}/`);
---
<Base title="Our Weekend Plans">
  <div class="page">
    <div class="marquee-bar">
      <Marquee items={marqueeItems(latestNo, latest.data)} />
    </div>

    <div class="home">
      <!-- masthead -->
      <header class="masthead">
        <div>
          <div class="kicker">A love note with logistics · Jakarta</div>
          <h1 class="wordmark">Our Weekend<br />Plans</h1>
        </div>
        <div class="masthead__meta">
          <div>No. {latestNo}</div>
          <div>{latest.data.dateRange}</div>
          <div class="masthead__fresh">Fresh for you two 💛</div>
        </div>
      </header>
      <div class="bleed"><div class="hr-ink"></div></div>

      <!-- cover spread -->
      <section class="spread">
        <a
          class="cover-tile"
          href={latestHref}
          style={`background:${latestCover.bg};color:${latestCover.fg}`}
        >
          <div class="cover-tile__grain"></div>
          <div class="cover-tile__top">
            <span>Plan No. {latestNo}</span>
            <span>{latest.data.dateRange} · {latest.data.year}</span>
          </div>
          <div class="cover-tile__bottom">
            <div class="cover-tile__weather">
              <Weather kind={latest.data.weather.kind} color={latestCover.fg} size={17} />
              <span>{latest.data.weather.label} · {latest.data.weather.hi}</span>
            </div>
            <h2 class="cover-tile__title">{latest.data.title}</h2>
            <p class="cover-tile__teaser">{latest.data.teaser}</p>
          </div>
        </a>

        <!-- contents -->
        <div class="contents">
          <div class="contents__eyebrow">The plan this weekend</div>
          <div class="contents__sub">
            a {latest.data.picks.length}-stop plan for the two of you
          </div>
          <ol class="contents__list">
            {latest.data.picks.map((pick) => (
              <li>
                <a class="pick" href={latestHref}>
                  <span class="pick__no" style={`color:${areaColor(pick.area)}`}>
                    {pick.no}
                  </span>
                  <span class="pick__body">
                    <span class="pick__name">{pick.name}</span>
                    <span class="pick__meta">
                      {pick.area} · {pick.date} · {pick.budget}
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ol>
          <a class="btn-read" href={latestHref}>
            See the full plan <span class="btn-read__arrow">→</span>
          </a>
        </div>
      </section>

      <!-- back issues -->
      <section class="back">
        <div class="back__head">
          <h3>Plans we've made</h3>
          <span class="back__count">{archive.length} weekends planned &amp; counting</span>
        </div>
        <div class="back__grid">
          {archive.map((iss) => {
            const cv = cover(iss.data.cover);
            return (
              <a
                class="issue-card"
                href={withBase(`issues/${iss.id}/`)}
                style={`background:${cv.bg};color:${cv.fg}`}
              >
                <div class="issue-card__grain"></div>
                <div class="issue-card__top">
                  <span>No. {numbers.get(iss.id)}</span>
                  <span>{iss.data.dateRange}</span>
                </div>
                <div class="issue-card__bottom">
                  <h4>{iss.data.title}</h4>
                  <span class="issue-card__read">Relive it →</span>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    </div>
  </div>
</Base>

<style>
  .page {
    color: var(--ink);
    position: relative;
    min-height: 100vh;
    width: 100%;
  }
  .marquee-bar {
    border-bottom: 1.5px solid var(--ink);
  }
  .home {
    background: var(--paper);
    min-height: 100vh;
    padding-bottom: 120px;
    animation: gmRise 0.5s var(--ease-out) both;
  }

  /* masthead */
  .masthead {
    max-width: 1240px;
    margin: 0 auto;
    padding: 28px clamp(20px, 5vw, 64px) 18px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 8px;
  }
  .wordmark {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(34px, 6vw, 68px);
    line-height: 0.92;
    letter-spacing: -0.025em;
    color: var(--ink);
  }
  .masthead__meta {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--taupe);
    line-height: 1.9;
  }
  .masthead__fresh { color: var(--rust); }

  .bleed {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(20px, 5vw, 64px);
  }
  .hr-ink { height: 1.5px; background: var(--ink); }

  /* cover spread */
  .spread {
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px) clamp(20px, 5vw, 64px) 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(330px, 1fr));
    gap: clamp(24px, 3vw, 48px);
    align-items: stretch;
  }

  .cover-tile {
    border: 1.5px solid var(--ink);
    border-radius: 14px;
    overflow: hidden;
    text-align: left;
    text-decoration: none;
    min-height: 440px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: 0 18px 44px rgba(34, 28, 22, 0.13);
    transition: transform 0.3s var(--ease-out);
  }
  .cover-tile:hover { transform: translateY(-4px); }
  .cover-tile__grain {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.07) 1px, transparent 0);
    background-size: 13px 13px;
    pointer-events: none;
  }
  .cover-tile__top {
    position: relative;
    padding: 26px 28px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .cover-tile__bottom { position: relative; padding: 0 28px 28px; }
  .cover-tile__weather {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.85;
    margin-bottom: 14px;
  }
  .cover-tile__title {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(30px, 4.4vw, 52px);
    line-height: 0.95;
    letter-spacing: -0.02em;
  }
  .cover-tile__teaser {
    margin: 14px 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(15px, 1.5vw, 19px);
    line-height: 1.4;
    max-width: 30ch;
    opacity: 0.92;
  }

  /* contents */
  .contents { display: flex; flex-direction: column; }
  .contents__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--rust);
    margin-bottom: 6px;
  }
  .contents__sub {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18px;
    color: var(--taupe);
    margin-bottom: 18px;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 18px;
  }
  .contents__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .pick {
    width: 100%;
    text-align: left;
    text-decoration: none;
    border-bottom: 1px solid #E8DFCD;
    padding: 15px 4px;
    display: flex;
    gap: 18px;
    align-items: baseline;
    transition: padding-left 0.25s var(--ease-out), background 0.2s;
  }
  .pick:hover { padding-left: 12px; background: var(--cream); }
  .pick__no {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 22px;
    min-width: 30px;
  }
  .pick__body { flex: 1; }
  .pick__name {
    display: block;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 19px;
    line-height: 1.2;
    color: var(--ink);
  }
  .pick__meta {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #8A8073;
    margin-top: 4px;
  }
  .btn-read {
    margin-top: 24px;
    align-self: flex-start;
    background: var(--clay);
    color: var(--cream);
    border: 1.5px solid var(--ink);
    border-radius: 999px;
    padding: 14px 26px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    transition: background 0.2s, transform 0.15s;
  }
  .btn-read:hover { background: #8F3318; }
  .btn-read:active { transform: translateY(1px); }
  .btn-read__arrow { font-size: 18px; }

  /* back issues */
  .back {
    max-width: 1240px;
    margin: 0 auto;
    padding: clamp(48px, 6vw, 88px) clamp(20px, 5vw, 64px) 40px;
  }
  .back__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 14px;
    margin-bottom: 28px;
    gap: 16px;
    flex-wrap: wrap;
  }
  .back__head h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(22px, 3vw, 34px);
    letter-spacing: -0.02em;
  }
  .back__count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--taupe);
  }
  .back__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: clamp(18px, 2.2vw, 28px);
  }
  .issue-card {
    text-align: left;
    text-decoration: none;
    border: 1.5px solid var(--ink);
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    position: relative;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s;
  }
  .issue-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 36px rgba(34, 28, 22, 0.16);
  }
  .issue-card__grain {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(0, 0, 0, 0.06) 1px, transparent 0);
    background-size: 12px 12px;
    pointer-events: none;
  }
  .issue-card__top {
    position: relative;
    padding: 16px 18px;
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .issue-card__bottom { position: relative; padding: 0 18px 18px; }
  .issue-card__bottom h4 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 23px;
    line-height: 0.98;
    letter-spacing: -0.015em;
  }
  .issue-card__read {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.85;
  }
</style>
