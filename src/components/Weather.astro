---
// Weather glyph — sun / rain / cloud. Paths lifted from the original wIcon().
interface Props {
  kind: 'sun' | 'rain' | 'cloud';
  color?: string;
  size?: number;
}
const { kind, color = '#332B22', size = 17 } = Astro.props;
const sunRays = [
  'M12 2v2', 'M12 20v2', 'M4.9 4.9l1.4 1.4', 'M17.7 17.7l1.4 1.4',
  'M2 12h2', 'M20 12h2', 'M4.9 19.1l1.4-1.4', 'M17.7 6.3l1.4-1.4',
];
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke={color}
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  style="flex:none"
  aria-hidden="true"
>
  {kind === 'rain' && (
    <>
      <path d="M16 13a4 4 0 0 0-1-7.5A5.5 5.5 0 0 0 4.5 11 3.5 3.5 0 0 0 6 18h9" />
      <line x1="8" y1="19" x2="8" y2="21" />
      <line x1="12" y1="19" x2="12" y2="22" />
      <line x1="16" y1="19" x2="16" y2="21" />
    </>
  )}
  {kind === 'cloud' && (
    <path d="M17.5 18a4.5 4.5 0 0 0 .5-9 6 6 0 0 0-11.4-1.5A4 4 0 0 0 7 18z" />
  )}
  {kind === 'sun' && (
    <>
      <circle cx="12" cy="12" r="4" />
      {sunRays.map((d) => <path d={d} />)}
    </>
  )}
</svg>
